.container { padding: 30rpx; background-color: #f5f5f5; min-height: 100vh; }
.form-item { margin-bottom: 40rpx; background-color: #fff; padding: 25rpx; border-radius: 15rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03); }
.label { display: block; font-size: 28rpx; color: #333; margin-bottom: 15rpx; }
.input, .picker-text { width: 100%; font-size: 28rpx; padding: 15rpx 0; border-bottom: 1rpx solid #eee; }
.picker { width: 100%; }
.radio-group { display: flex; flex-direction: column; gap: 20rpx; margin-top: 15rpx; }
.radio-label { display: flex; align-items: center; font-size: 28rpx; }
.radio-label radio { margin-right: 15rpx; }
.submit-btn { margin-top: 60rpx; background-color: #4CAF50; color: white; padding: 20rpx; border-radius: 15rpx; font-size: 32rpx; }