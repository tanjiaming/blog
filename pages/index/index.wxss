.container { padding: 20rpx; box-sizing: border-box; min-height: 100vh; background-color: #f5f5f5; }
.header { text-align: center; margin: 60rpx 0; }
.title { font-size: 40rpx; font-weight: bold; color: #333; }
.subtitle { display: block; margin-top: 10rpx; font-size: 28rpx; color: #666; }
.btn-group { display: flex; flex-direction: column; gap: 30rpx; padding: 40rpx; }
.btn { display: flex; align-items: center; justify-content: center; padding: 30rpx; background-color: #fff; border-radius: 15rpx; box-shadow: 0 5rpx 15rpx rgba(0,0,0,0.05); }
.btn-icon { width: 60rpx; height: 60rpx; margin-right: 20rpx; }
.btn text { font-size: 32rpx; color: #333; }