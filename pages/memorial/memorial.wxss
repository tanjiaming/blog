.container { padding: 30rpx; background-color: #f5f5f5; min-height: 100vh; }
.form-item { margin-bottom: 40rpx; background-color: #fff; padding: 25rpx; border-radius: 15rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03); }
.label { display: block; font-size: 28rpx; color: #333; margin-bottom: 15rpx; }
.input, .picker-text { width: 100%; font-size: 28rpx; padding: 15rpx 0; border-bottom: 1rpx solid #eee; }
.textarea { width: 100%; height: 200rpx; padding: 15rpx; border: 1rpx solid #eee; border-radius: 10rpx; font-size: 28rpx; margin-top: 15rpx; }
.upload-area { display: flex; flex-direction: column; align-items: center; padding: 40rpx 0; border: 2rpx dashed #ccc; border-radius: 15rpx; margin-top: 15rpx; }
.upload-img { width: 120rpx; height: 120rpx; margin-bottom: 20rpx; }
.upload-text { font-size: 28rpx; color: #666; }
.save-btn { margin-top: 60rpx; background-color: #2196F3; color: white; padding: 20rpx; border-radius: 15rpx; font-size: 32rpx; }